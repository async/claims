{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://async.dev/schemas/claims.config.schema.json",
  "title": "Async Claims Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "registry": {
      "type": "string",
      "minLength": 1,
      "default": "tests/claims.json"
    },
    "testFiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": ["tests/**/*.test.js"]
    },
    "testTitlePattern": {
      "type": "string",
      "minLength": 1,
      "default": "^\\s*test\\(\\s*\"((?:[^\"\\\\]|\\\\.)*)\""
    },
    "promisePrefix": {
      "type": "string",
      "minLength": 1,
      "default": "PROMISE: "
    }
  }
}
