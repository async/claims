{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://async.dev/schemas/claims.schema.json",
  "title": "Async Claims Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["claims"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "$comment": {
      "type": "string"
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "anchor", "tests"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "anchor": {
            "type": "string",
            "minLength": 1
          },
          "tests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
