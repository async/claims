{
  "name": "@async/claims",
  "version": "0.1.0",
  "description": "Deterministic documentation-claim coverage checks for tests and AI-assisted release loops.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/async/claim.git"
  },
  "bugs": {
    "url": "https://github.com/async/claim/issues"
  },
  "homepage": "https://github.com/async/claim#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "default": "./dist/pipeline.js"
    },
    "./schema/claims.config.schema.json": "./schema/claims.config.schema.json",
    "./schema/claims.schema.json": "./schema/claims.schema.json"
  },
  "bin": {
    "async-claims": "./dist/cli.js"
  },
  "scripts": {
    "api:check": "pnpm run pipeline:task:api.surface",
    "build": "pnpm run pipeline:task:build",
    "claims:check": "pnpm run pipeline:task:claims",
    "pack:check": "pnpm run pipeline:task:pack.check",
    "pages:build": "pnpm run pipeline:task:docs.site",
    "pipeline:github:check": "async-pipeline github check",
    "pipeline:github:generate": "async-pipeline github generate",
    "pipeline:pages": "async-pipeline run pages",
    "pipeline:preview": "async-pipeline run preview",
    "pipeline:publish": "async-pipeline run publish",
    "pipeline:publish:github:release": "async-pipeline publish github release --package .",
    "pipeline:publish:npm": "async-pipeline publish npm --package .",
    "pipeline:release:doctor": "async-pipeline release doctor --package .",
    "pipeline:release:ensure": "async-pipeline release ensure --package .",
    "pipeline:releaseDoctor": "async-pipeline run releaseDoctor",
    "pipeline:snapshot": "async-pipeline run snapshot",
    "pipeline:sync:check": "async-pipeline sync check",
    "pipeline:sync:generate": "async-pipeline sync generate",
    "pipeline:task:api.surface": "async-pipeline run-task api.surface",
    "pipeline:task:build": "async-pipeline run-task build",
    "pipeline:task:claims": "async-pipeline run-task claims",
    "pipeline:task:claims.repair": "async-pipeline run-task claims.repair",
    "pipeline:task:claims.report": "async-pipeline run-task claims.report",
    "pipeline:task:docs.site": "async-pipeline run-task docs.site",
    "pipeline:task:pack.check": "async-pipeline run-task pack.check",
    "pipeline:task:publish.preview": "async-pipeline run-task publish.preview",
    "pipeline:task:publish.snapshot": "async-pipeline run-task publish.snapshot",
    "pipeline:task:publish.stable": "async-pipeline run-task publish.stable",
    "pipeline:task:publish.stable.github": "async-pipeline run-task publish.stable.github",
    "pipeline:task:release.doctor": "async-pipeline run-task release.doctor",
    "pipeline:task:release.ensure": "async-pipeline run-task release.ensure",
    "pipeline:task:test": "async-pipeline run-task test",
    "pipeline:task:verify": "async-pipeline run-task verify",
    "pipeline:verify": "async-pipeline run verify",
    "release:check": "pnpm run pipeline:verify",
    "release:doctor": "pnpm run pipeline:release:doctor",
    "release:publish": "pnpm run pipeline:publish",
    "test": "pnpm run pipeline:task:test"
  },
  "files": [
    "API_SURFACE.md",
    "api-contract.json",
    "dist",
    "schema",
    "docs",
    "examples",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@async/api-contract": "0.1.0",
    "@async/pipeline": "0.4.3",
    "@types/node": "24.12.4",
    "typescript": "6.0.3"
  }
}
